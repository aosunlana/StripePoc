@page "/"
@using StripePoc.Blazor.Models.Subscriptions
@using StripePoc.Blazor.Models.PaymentIntents
@using StripePoc.Blazor.Components
@inject Microsoft.JSInterop.IJSRuntime JSRuntime
@inject StripePoc.Blazor.Services.ApiService ApiService

<PageTitle>Stripe POC - Modern Payments</PageTitle>

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Subscription POC</h1>
        <p class="lead text-secondary">A complete end-to-end simulation of the Stripe lifecycle.</p>
        
        <div class="step-progress mt-4 mx-auto" style="max-width: 600px;">
            <div class="progress" style="height: 4px;">
                <div class="progress-bar" role="progressbar" style="width: @(GetProgressWidth())%"></div>
            </div>
            <div class="d-flex justify-content-between mt-2 small text-muted">
                <span class="@(currentStep == Step.Identity ? "text-primary fw-bold" : "")">Identity</span>
                <span class="@(currentStep == Step.Wallet ? "text-primary fw-bold" : "")">Wallet</span>
                <span class="@(currentStep == Step.Pricing ? "text-primary fw-bold" : "")">Pricing</span>
                <span class="@(currentStep == Step.ActionSelect ? "text-primary fw-bold" : "")">Action</span>
                <span class="@(currentStep == Step.Outcome ? "text-primary fw-bold" : "")">Outcome</span>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="main-card shadow-lg border-0 rounded-4 overflow-hidden mb-5">
                <div class="card-body p-0">
                    @if (currentStep == Step.Identity)
                    {
                        <AccountSelector OnAccountSelected="HandleAccountSelected" />
                    }
                    else if (currentStep == Step.Wallet)
                    {
                        <WalletComponent SelectedAccount="selectedAccount" OnSetupComplete="HandleWalletComplete" />
                        <div class="px-4 pb-4">
                             <button class="btn btn-link text-muted" @onclick="() => currentStep = Step.Identity">← Change Account</button>
                        </div>
                    }
                    else if (currentStep == Step.Pricing)
                    {
                        <PricingComponent OnServiceSelected="HandlePricingSelected" />
                        <div class="px-4 pb-4">
                             <button class="btn btn-link text-muted" @onclick="() => currentStep = Step.Wallet">← Change Wallet</button>
                        </div>
                    }
                    else if (currentStep == Step.ActionSelect)
                    {
                        <div class="p-5 text-center">
                            <h3 class="mb-4">Select Payment Type</h3>
                            <div class="row g-4 mb-4">
                                <div class="col-md-6">
                                    <button class="btn btn-outline-primary w-100 p-4 h-100" @onclick="() => ExecuteAction(true)">
                                        <div class="fs-1 mb-2">🔄</div>
                                        <h5 class="fw-bold">Start Weekly Subscription</h5>
                                        <p class="small text-muted mb-0">Automatic recurring charges</p>
                                    </button>
                                </div>
                                <div class="col-md-6">
                                    <button class="btn btn-outline-success w-100 p-4 h-100" @onclick="() => ExecuteAction(false)">
                                        <div class="fs-1 mb-2">⚡</div>
                                        <h5 class="fw-bold">One-Time Payment</h5>
                                        <p class="small text-muted mb-0">Single immediate charge</p>
                                    </button>
                                </div>
                            </div>
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <button class="btn btn-outline-info w-100 p-4 h-100" @onclick="() => ExecuteQuoteAction(true)">
                                        <div class="fs-1 mb-2">📝</div>
                                        <h5 class="fw-bold">Legal Approval (Sub)</h5>
                                        <p class="small text-muted mb-0">Customer approves via Quote first</p>
                                    </button>
                                </div>
                                <div class="col-md-6">
                                    <button class="btn btn-outline-info w-100 p-4 h-100" @onclick="() => ExecuteQuoteAction(false)">
                                        <div class="fs-1 mb-2">📄</div>
                                        <h5 class="fw-bold">Legal Approval (One-time)</h5>
                                        <p class="small text-muted mb-0">Customer sign-off before charge</p>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                    else if (currentStep == Step.Outcome)
                    {
                        <div class="p-5">
                            <div class="text-center success-animation mb-5">
                                <div class="checkmark-circle">
                                    <div class="background"></div>
                                    <div class="checkmark draw"></div>
                                </div>
                                <h2 class="mt-4">Action Triggered Successfully!</h2>
                                <p class="lead text-muted">Stripe is processing your @(isSubscription ? "subscription" : "payment").</p>
                            </div>

                            <div class="row g-4 mb-5">
                                <div class="col-md-6">
                                    <div class="card h-100 border-0 bg-light p-4">
                                        <h6 class="text-uppercase fw-bold text-secondary mb-3 small">Transaction Lifecycle</h6>
                                        <div class="d-grid gap-2">
                                            @if (isSubscription)
                                            {
                                                <button class="btn btn-outline-danger fw-bold" @onclick="CancelActiveSubscription" disabled="@isProcessing">
                                                    Cancel Subscription
                                                </button>
                                            }
                                            <button class="btn btn-outline-warning fw-bold" @onclick="RefundLastTransaction" disabled="@isProcessing">
                                                Refund Last Payment
                                            </button>
                                            <button class="btn btn-primary mt-2 fw-bold" @onclick="() => currentStep = Step.Identity">
                                                Start New Session
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card h-100 border-0 bg-light p-4">
                                        <h6 class="text-uppercase fw-bold text-secondary mb-3 small">Active Session Info</h6>
                                        <p class="mb-1 small">Account: <strong>@selectedAccount.Name</strong></p>
                                        <p class="mb-1 small">Amount: <strong>$@((selectedPricing.Amount / 100.0).ToString("N2"))</strong></p>
                                        <p class="mb-0 small">Status: <span class="badge bg-success">Success</span></p>
                                    </div>
                                </div>
                            </div>

                            <h5 class="fw-bold mb-3 d-flex justify-content-between align-items-center">
                                Local Account History
                                <button class="btn btn-sm btn-link" @onclick="LoadHistory">Refresh</button>
                            </h5>
                            <div class="table-responsive bg-white rounded-3 shadow-sm">
                                <table class="table table-hover mb-0">
                                    <thead class="bg-light small">
                                        <tr>
                                            <th>Type</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                            <th>Reference</th>
                                            <th>Date</th>
                                        </tr>
                                    </thead>
                                    <tbody class="small">
                                        @if (paymentHistory == null || !paymentHistory.Any())
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-4 text-muted">No transactions found for this account.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var p in paymentHistory.OrderByDescending(x => x.PaidAt))
                                            {
                                                <tr>
                                                    <td><strong>@p.Type</strong></td>
                                                    <td>$@((p.Amount / 100.0).ToString("N2"))</td>
                                                    <td><span class="badge @(p.Status == StripePoc.Blazor.Models.Payments.PaymentStatus.Succeeded ? "bg-success" : "bg-danger")">@p.Status</span></td>
                                                    <td class="text-muted">@p.StripeReferenceId.Substring(0, Math.Min(12, p.StripeReferenceId.Length))...</td>
                                                    <td>@p.PaidAt.ToString("MMM dd, HH:mm")</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                    else if (currentStep == Step.QuotePending)
                    {
                        <div class="p-5 text-center">
                            <div class="mb-4">
                                <i class="bi bi-envelope-check fs-1 text-info"></i>
                            </div>
                            <h2 class="fw-bold">Approval Request Sent!</h2>
                            <p class="lead text-muted mb-5">
                                A formal Stripe Quote has been generated. The customer must review and accept it before the charge occurs.
                            </p>
                            
                            <div class="card border-0 bg-light p-4 mb-4 mx-auto" style="max-width: 500px;">
                                <h6 class="text-uppercase fw-bold text-secondary mb-3 small">Quote Reference: @activeQuote.ExternalReferenceId</h6>
                                <div class="d-grid gap-2">
                                    <a href="@activeQuote.CheckoutUrl" target="_blank" class="btn btn-info btn-lg fw-bold text-white shadow-sm">
                                        Open Approval Link (Customer View)
                                    </a>
                                    <button class="btn btn-outline-secondary mt-2" @onclick="() => currentStep = Step.Identity">
                                        Back to Dashboard
                                    </button>
                                </div>
                                <div class="mt-3 small text-muted">
                                    <i class="bi bi-shield-check me-1"></i>
                                    Once accepted, Stripe will automatically charge the card currently on file.
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger shadow-sm border-0 rounded-3">@errorMessage</div>
            }
        </div>
    </div>
</div>

@code {
    private enum Step { Identity, Wallet, Pricing, ActionSelect, Outcome, QuotePending }
    private Step currentStep = Step.Identity;
    private bool isProcessing = false;
    private string errorMessage = "";
    private StripePoc.Blazor.Models.Events.PaymentLifecycleEvent activeQuote;

    // State Data
    private StripePoc.Blazor.Models.Accounts.Account selectedAccount;
    private PricingComponent.ServiceSelection selectedPricing;
    private bool isSubscription = false;
    private List<StripePoc.Blazor.Models.Payments.Payment> paymentHistory;

    private int GetProgressWidth() => (int)currentStep * 25;

    private void HandleAccountSelected(StripePoc.Blazor.Models.Accounts.Account account)
    {
        selectedAccount = account;
        currentStep = Step.Wallet;
    }

    private void HandleWalletComplete(StripePoc.Blazor.Models.PaymentMethods.PaymentMethod method)
    {
        currentStep = Step.Pricing;
    }

    private void HandlePricingSelected(PricingComponent.ServiceSelection pricing)
    {
        selectedPricing = pricing;
        currentStep = Step.ActionSelect;
    }

    private async Task ExecuteAction(bool subscriptionMode)
    {
        isSubscription = subscriptionMode;
        isProcessing = true;
        errorMessage = "";

        try
        {
            if (isSubscription)
            {
                var subRequest = new StripePoc.Blazor.Models.Subscriptions.Subscription
                {
                    AccountId = selectedAccount.Id,
                    ServiceName = selectedPricing.ServiceName,
                    Amount = selectedPricing.Amount,
                    Currency = selectedPricing.Currency,
                    IntervalCount = 1,
                    Status = StripePoc.Blazor.Models.Subscriptions.SubscriptionStatus.Incomplete
                };
                await ApiService.CreateSubscriptionAsync(subRequest);
            }
            else
            {
                var payRequest = new StripePoc.Blazor.Models.PaymentIntents.PaymentIntent
                {
                    AccountId = selectedAccount.Id,
                    Amount = selectedPricing.Amount,
                    Currency = selectedPricing.Currency
                };
                await ApiService.ProcessOneTimePaymentAsync(payRequest);
            }

            await LoadHistory();
            currentStep = Step.Outcome;
        }
        catch (Exception ex)
        {
            errorMessage = "Execution failed: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task ExecuteQuoteAction(bool subscriptionMode)
    {
        isSubscription = subscriptionMode;
        isProcessing = true;
        errorMessage = "";

        try
        {
            if (isSubscription)
            {
                var subRequest = new StripePoc.Blazor.Models.Subscriptions.Subscription
                {
                    AccountId = selectedAccount.Id,
                    ServiceName = selectedPricing.ServiceName,
                    Amount = selectedPricing.Amount,
                    Currency = selectedPricing.Currency,
                    IntervalCount = 1
                };
                activeQuote = await ApiService.CreateSubscriptionQuoteAsync(subRequest);
            }
            else
            {
                var payRequest = new StripePoc.Blazor.Models.PaymentIntents.PaymentIntent
                {
                    AccountId = selectedAccount.Id,
                    Amount = selectedPricing.Amount,
                    Currency = selectedPricing.Currency
                };
                activeQuote = await ApiService.ProcessOneTimeQuotePaymentAsync(payRequest);
            }

            currentStep = Step.QuotePending;
        }
        catch (Exception ex)
        {
            errorMessage = "Quote request failed: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task LoadHistory()
    {
        try
        {
            paymentHistory = await ApiService.GetPaymentHistoryAsync(selectedAccount.Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine("History Error: " + ex.Message);
        }
    }

    private async Task RefundLastTransaction()
    {
        isProcessing = true;
        errorMessage = "";
        try
        {
            await ApiService.RefundLastPaymentAsync(selectedAccount.Id);
            await Task.Delay(2000); // Give webhook time
            await LoadHistory();
        }
        catch (Exception ex)
        {
            errorMessage = "Refund failed: " + ex.Message;
        }
        finally { isProcessing = false; }
    }

    private async Task CancelActiveSubscription()
    {
        isProcessing = true;
        errorMessage = "";
        try
        {
            var subs = await ApiService.GetSubscriptionsAsync(selectedAccount.Id);
            var activeSub = subs.FirstOrDefault(s => s.Status == StripePoc.Blazor.Models.Subscriptions.SubscriptionStatus.Active);
            
            if (activeSub != null)
            {
                await ApiService.CancelSubscriptionAsync(activeSub.Id);
                await Task.Delay(2000); // Give webhook time
                await LoadHistory();
            }
            else
            {
                errorMessage = "No active subscription found to cancel.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Cancellation failed: " + ex.Message;
        }
        finally { isProcessing = false; }
    }
}

<style>
    body {
        background-color: #f0f2f5;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }
    .text-primary { color: #6772e5 !important; }
    .btn-primary { background-color: #6772e5; border: none; }
    .btn-primary:hover { background-color: #5469d4; }
    
    /* Success Animation */
    .checkmark-circle {
        width: 150px;
        height: 150px;
        position: relative;
        display: inline-block;
        vertical-align: top;
        margin-bottom: 2rem;
    }
    .checkmark-circle .background {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: #28a745;
        position: absolute;
    }
    .checkmark-circle .checkmark {
        border-radius: 5px;
    }
    .checkmark-circle .checkmark.draw:after {
        animation-duration: 800ms;
        animation-timing-function: ease;
        animation-name: checkmark;
        transform: scaleX(-1) rotate(135deg);
    }
    .checkmark-circle .checkmark:after {
        opacity: 1;
        height: 75px;
        width: 37.5px;
        transform-origin: left top;
        border-right: 15px solid #fff;
        border-top: 15px solid #fff;
        content: '';
        left: 37.5px;
        top: 75px;
        position: absolute;
    }
    @@keyframes checkmark {
        0% { height: 0; width: 0; opacity: 1; }
        20% { height: 0; width: 37.5px; opacity: 1; }
        40% { height: 75px; width: 37.5px; opacity: 1; }
        100% { height: 75px; width: 37.5px; opacity: 1; }
    }
</style>
